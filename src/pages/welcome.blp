using Gtk 4.0;
using Adw 1;

template $ElevenWelcomePage: Adw.Bin {
    child: Adw.ToolbarView {
        [top]
        Adw.HeaderBar {
            show-title: false;
        }
        
        Label heading {
            label: "";

            styles [
                "title-1"
            ]
        }
    };
}