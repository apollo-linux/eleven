#!@PYTHON@


import os
import sys
import signal
import locale
import gettext

VERSION = '@VERSION@'
pkgdatadir = '@pkgdatadir@'
localedir = '@localedir@'

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)
locale.bindtextdomain('eleven', localedir)
locale.textdomain('eleven')
gettext.bindtextdomain('eleven', localedir)
gettext.textdomain('eleven')

if __name__ == '__main__':
    import gi

    from gi.repository import Gio
    resource = Gio.Resource.load(os.path.join(pkgdatadir, 'eleven.gresource'))
    resource._register()

    from eleven import main
    sys.exit(main.main(VERSION))
